VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Gemini OCR is server-side. Do not add a VITE_GEMINI_API_KEY.
# Configure these as Supabase Edge Function secrets instead:
# GEMINI_API_KEY=your-new-gemini-key
# GEMINI_MODEL=gemini-2.5-flash

# Existing Toast sync worker used by previous working releases
VITE_TOAST_SYNC_API_URL=https://render-toast-web-service.onrender.com
