SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

TOAST_SFTP_HOST=s-xxxxxxxxxxxxxxxxx.server.transfer.us-east-1.amazonaws.com
TOAST_SFTP_PORT=22
TOAST_SFTP_USERNAME=your-toast-sftp-username
TOAST_PRIVATE_KEY_PATH=/etc/secrets/toast_restapay
# TOAST_PRIVATE_KEY_PASSPHRASE=only-if-your-key-is-encrypted
TOAST_EXPORT_ID=144385
TOAST_LOOKBACK_DAYS=8
TOAST_TIMEZONE=America/Chicago

# Built-in automatic daily sync. Set false when using a separate Render Cron Job.
TOAST_AUTO_SYNC_ENABLED=true
TOAST_AUTO_SYNC_HOUR=6
TOAST_AUTO_SYNC_MINUTE=30
TOAST_SYNC_TIMEOUT_MS=1800000

ALLOWED_ORIGIN=https://your-restapay-site.onrender.com
PORT=3001
