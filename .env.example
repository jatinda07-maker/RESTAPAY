VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Gemini OCR is server-side. Do not add a VITE_GEMINI_API_KEY.
# Configure these as Supabase Edge Function secrets instead:
# GEMINI_API_KEY=your-new-gemini-key
# GEMINI_MODEL=gemini-2.5-flash

# Public URL of the separate Render Toast Sync web service
VITE_TOAST_SYNC_API_URL=https://your-toast-sync-service.onrender.com

# Optional: only needed when TOAST_SYNC_API_KEY is set on the Render Toast API.
# VITE_TOAST_SYNC_API_KEY=do-not-use-in-production-browser-builds
