VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini invoice extraction
# Create a real .env file in the project root and put your key here.
# Restart npm run dev after changing this file.
VITE_GEMINI_API_KEY=your-gemini-api-key

# Optional. Leave blank to use automatic fallback models.
# Current API docs use gemini-3.5-flash for generateContent.
VITE_GEMINI_MODEL=gemini-3.5-flash

# RC8 Toast Sync backend URL (no trailing slash)
VITE_TOAST_SYNC_API_URL=https://your-toast-sync-service.onrender.com
